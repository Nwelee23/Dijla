# Dijla — environment template.
# Copy this file to `.env.local` and fill in the real values.
# `.env*` is gitignored — NEVER commit real keys.

# --- Supabase ---
# Supabase dashboard → Project Settings → API Keys
#
# Supabase renamed its keys. On the "Publishable and secret API keys" tab:
#   Publishable key (sb_publishable_...) -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Secret key      (sb_secret_...)      -> SUPABASE_SERVICE_ROLE_KEY
# The variable names below keep the classic wording used throughout the build brief.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key. Safe in the browser — protected by Row-Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Secret key. SERVER ONLY — bypasses RLS. Never prefix with NEXT_PUBLIC_, never send to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Supabase CLI (local development only, not needed at runtime) ---
# Used by `npm run db:types` to regenerate src/lib/supabase/types.ts.
# Create one at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Your Supabase project ref (the subdomain in NEXT_PUBLIC_SUPABASE_URL).
# Used by `npm run db:types`. Not a secret, but kept out of the committed script.
SUPABASE_PROJECT_ID=your-project-ref

# --- App ---
# Shown to a restaurant whose trial has ended, so they can call you to activate.
NEXT_PUBLIC_SUPPORT_PHONE=+9647700000000

# Public base URL, used to build table QR links (Phase 2). Localhost in dev, the Vercel URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Web Push (REDESIGN_V2_SPEC §11) ---
# Generate a pair once with: npx web-push generate-vapid-keys
# Public key is exposed to the browser (safe); private key is SERVER ONLY.
# Without these, push simply no-ops — the in-page alert still works.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
